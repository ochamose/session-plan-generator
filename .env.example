# Server Configuration
PORT=3000
NODE_ENV=development

# Claude API Key (recommended: set here instead of entering in browser)
# Get yours from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Set if you want to restrict allowed origins
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional: Set maximum file upload size (in MB)
# MAX_FILE_SIZE=10
